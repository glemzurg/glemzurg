{
    "name": "Process Payment",
    "details": "Charges the customer's payment method and records the transaction",
    "requires": [
        {
            "type": "assessment",
            "description": "Order total must be greater than zero",
            "notation": "tla_plus"
        },
        {
            "type": "assessment",
            "description": "Customer payment method must be valid and active",
            "notation": "tla_plus"
        },
        {
            "type": "assessment",
            "description": "Order must not already be paid",
            "notation": "tla_plus"
        }
    ],
    "guarantees": [
        {
            "type": "state_change",
            "description": "Payment has been charged to customer's payment method",
            "target": "payment_status",
            "notation": "tla_plus"
        },
        {
            "type": "state_change",
            "description": "Transaction record has been created",
            "target": "transaction",
            "notation": "tla_plus"
        },
        {
            "type": "state_change",
            "description": "Order payment status is set to paid",
            "target": "order_status",
            "notation": "tla_plus"
        }
    ]
}