# Book Order

A Book Order represents a Customer's request for a specified set (and quantity) of books.

◇

attributes:
    id:
        name: "id"
        index_nums: [0] # Index zero is "key"
        details: The identifier (key) of the Book order. This used to be outside Order Fullfillment to correlate Books Orders with external business processes.
        rules: refer to Corporate Policy CP123a, "Customer Order Identification"
    opened:
        name: "date opened"
        details: The date this Book Order was created, this is, the first Book Order Line was added.
        rules: calendar date no earlier than Janurary 1, 1998, and no later than today, to the nearest whole day
    shipping:
        name: "shipping address"
        details: The postal address the Customer is requesting any Print Media in the Book order be shipped to.
        rules: any mailing address acceptable to the US Post Office ro Canada Post
    state:
        name: "state"
        details: Shows the business processing status of this Book Order.
        rules: enumeration of the states in the state model
    is_packable:
        name: "is packable?"
        details: Shows if this Book Order is currently packable or not.
        derivation: true only when .state == placed and IsPackable? == true for each Line in this order (via For)
    sales:
        name: "sales?"
        details: Shows the total dollar sales amount of this Book Order.
        derivation: if .state == completed then sum of sales? for each Line (via For) otherwise $0.00
    profit:
        name: "profit?"
        details: Shows the amount of profit generated by this Book Order.
        derivation: if .state == completed then sum of profit? for each Line (via For) otherwise $0.00
    user_keys:
        name: "user keys?"
        details: provides user keys for eBook Media in this Book Order.
        derivation: if .state is not opened or cancelled then set of user key? from all Lines in this Order (via For) otherwise empty set

associations:

    - name: For
      from_multiplicity: "any"
      to_class_key: 01_order_fulfillment/medium
      to_multiplicity: "1..many"
      association_class_key: 01_order_fulfillment/book_order_line

states:

  Open:
    details: The order is created.

  Placed:
    details: This order is in process.

  Cancelled:
    details: The order has been cancelled.

  Packed:
    details: The order is boxed and ready to ship.

  Completed:
    details: The order is shipped.


events:

    "«new»":
        details: Create this Book Order.
        parameters:
            - name: address
              source: somewhere

    Drop:
        details: Remove a line from the Book Order.
        parameters:
            - name: "book order line"
              source: somewhere

    Add:
        details: Add a line to the Book Order.
        parameters:
            - name: medium
              source: somewhere
            - name: qty
              source: somewhere

    Place:
        details: Purchase the the Book Order.
        parameters:
            - name: address
              source: somewhere
    Cancel:
        details: Cancel the Book Order.

    Packed:
        details: The Book Order is ready to ship.

    Shipped:
        details: The Book Order has left the warehouse.


guards:

    OneLine:
        details: "=1 line"

    ManyLines:
        details: ">1 line"

    NoPrintMedium:
        details: "no print medium"

    HasPrintMedium:
        details: "has print medium"

    IsPackable:
        details: "isPackable?"

actions:

    Initialize:
        details: Start a new Book Order.
        requires:
            - address is consistent with the range of .shipping addresss
        guarantees:
            - |
                one new Book Order exists with:
                    .id properly assigned,
                    .date opened == today,
                    .shipping address == address

    DropLine:
        details: Remove a line from a book order.
        requires:
            - book order line exists in the Book Order via For
        guarantees:
            - referenced book order line has been deleted via For
    
    AddLine:
        details: Add an item to a Book Order.
        requires:
            - qty is consistent with the range of Book Order Line .quantity
        guarantees:
            - one new Book Order Line (this Book Order, medium, qty) has been created

    MarkAsPlaced:
        details: This book order has been made is is ready for delivery whether electronic or physical.
        requires:
            - address is consistent with the range of .shipping address
        guarantees:
            - .shipping address == address and place has been signaled for each line in the order via For

    MarkAsPacked:
        details: physical medium is all packed for shipping
        guarantees:
            - packed has been signaled for each line in the order via For

transitions:

    - {from: "", event: "«new»", to: "Open", action: "Initialize"}

    - {from: "Open", event: "Drop", to: "Open", guard: "ManyLines", action: "DropLine"}
    - {from: "Open", event: "Drop", to: "", guard: "OneLine", action: "DropLine"}
    - {from: "Open", event: "Add", to: "Open", action: "AddLine"}
    - {from: "Open", event: "Place", to: "Placed", guard: "HasPrintMedium", action: "MarkAsPlaced"}
    - {from: "Open", event: "Place", to: "Completed", guard: "NoPrintMedium", action: "MarkAsPlaced"}

    - {from: "Placed", event: "Cancel", to: "Cancelled"}
    - {from: "Placed", event: "Packed", to: "Packed", guard: "IsPackable", action: "MarkAsPacked"}

    - {from: "Packed", event: "Shipped", to: "Completed"}

